{
    "name": "waaseyaa/api",
    "description": "RESTful JSON:API resource layer for Waaseyaa",
    "type": "library",
    "license": "GPL-2.0-or-later",
    "repositories": [
        {
            "type": "path",
            "url": "../entity"
        },
        {
            "type": "path",
            "url": "../routing"
        },
        {
            "type": "path",
            "url": "../access"
        },
        {
            "type": "path",
            "url": "../plugin"
        },
        {
            "type": "path",
            "url": "../cache"
        },
        {
            "type": "path",
            "url": "../typed-data"
        },
        {
            "type": "path",
            "url": "../config"
        },
        {
            "type": "path",
            "url": "../foundation"
        },
        {
            "type": "path",
            "url": "../database-legacy"
        },
        {
            "type": "path",
            "url": "../telescope"
        }
    ],
    "require": {
        "php": ">=8.4",
        "waaseyaa/entity": "^0.1.0-alpha.150",
        "waaseyaa/foundation": "^0.1.0-alpha.150",
        "waaseyaa/routing": "^0.1.0-alpha.150",
        "waaseyaa/access": "^0.1.0-alpha.150"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "waaseyaa/database-legacy": "^0.1.0-alpha.150",
        "waaseyaa/telescope": "^0.1.0-alpha.150"
    },
    "autoload": {
        "psr-4": {
            "Waaseyaa\\Api\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Waaseyaa\\Api\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "extra": {
        "waaseyaa": {
            "providers": [
                "Waaseyaa\\Api\\ApiServiceProvider"
            ]
        },
        "branch-alias": {
            "dev-main": "0.1.x-dev",
            "dev-develop/v1.1": "0.1.x-dev"
        }
    },
    "config": {
        "sort-packages": true
    }
}
